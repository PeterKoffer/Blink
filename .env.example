# Blink v1 backend — environment template
# Copy to .env.{dev,staging,prod} and fill in real values. Never commit secrets.

# --- Runtime ---
BLINK_ENV=dev                         # dev | staging | prod
BLINK_LOG_LEVEL=info

# --- Postgres (Supabase) ---
# Use the direct connection string (transaction pooler for serverless, or direct for long-lived servers)
DATABASE_URL=postgresql://postgres:password@localhost:5432/blink

# --- Supabase Auth ---
# JWT secret from Supabase project settings (symmetric HS256 mode)
# In prod, prefer asymmetric JWKs via SUPABASE_JWKS_URL
SUPABASE_JWT_SECRET=replace_me
# Expected audience for issued JWTs (Supabase default: "authenticated")
SUPABASE_JWT_AUDIENCE=authenticated
# Issuer (your Supabase project URL + /auth/v1)
SUPABASE_JWT_ISSUER=https://your-project.supabase.co/auth/v1

# --- Cloudflare R2 (media storage — used in Sprint 4) ---
# Defined here so infra is consistent, not wired in Sprint 1.
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=blink-media
R2_ENDPOINT=

# --- Billing (Sprint 5) ---
# Placeholder for Stripe/Paddle integration. Not used in Sprint 1.
BILLING_PROVIDER=
BILLING_API_KEY=
